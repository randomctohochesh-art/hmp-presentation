<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Проект "Микробиом человека" (HMP)</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;500;700&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --neon-cyan: #00f5d4;
            --neon-blue: #00bbf9;
            --neon-purple: #9b5de5;
            --neon-pink: #f15bb5;
            --neon-yellow: #fee440;
            --dark-bg: #0a0a0f;
            --panel-bg: rgba(255,255,255,0.03);
        }

        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--dark-bg);
            color: #fff;
            overflow: hidden;
            cursor: crosshair;
        }

        /* Фоновая сетка */
        .grid-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(0,245,212,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0,245,212,0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            pointer-events: none;
            z-index: 1;
        }

        /* Плавающие частицы */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: var(--neon-cyan);
            border-radius: 50%;
            opacity: 0;
            animation: float-particle 8s infinite;
        }

        @keyframes float-particle {
            0% { opacity: 0; transform: translateY(100vh) scale(0); }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { opacity: 0; transform: translateY(-100vh) scale(1.5); }
        }

        .presentation {
            width: 100vw;
            height: 100vh;
            position: relative;
            z-index: 10;
        }

        .slide {
            width: 100%;
            height: 100%;
            position: absolute;
            top: 0;
            left: 0;
            display: none;
            padding: 60px;
            background: radial-gradient(ellipse at center, #1a1a2e 0%, var(--dark-bg) 100%);
        }

        .slide.active {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            animation: slide-in 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes slide-in {
            from { opacity: 0; transform: translateX(100px) scale(0.9); }
            to { opacity: 1; transform: translateX(0) scale(1); }
        }

        /* Навигация */
        .nav {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 20px;
            z-index: 1000;
        }

        .nav button {
            background: transparent;
            border: 2px solid var(--neon-cyan);
            color: var(--neon-cyan);
            padding: 12px 30px;
            border-radius: 0;
            cursor: pointer;
            font-family: 'Orbitron', sans-serif;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all 0.3s;
            clip-path: polygon(10% 0, 100% 0, 100% 70%, 90% 100%, 0 100%, 0 30%);
        }

        .nav button:hover {
            background: var(--neon-cyan);
            color: var(--dark-bg);
            box-shadow: 0 0 30px var(--neon-cyan);
        }

        .slide-counter {
            position: fixed;
            bottom: 30px;
            right: 40px;
            color: var(--neon-cyan);
            font-family: 'Orbitron', sans-serif;
            font-size: 18px;
            z-index: 1000;
            text-shadow: 0 0 10px var(--neon-cyan);
        }

        /* Глитч-заголовки */
        h1, h2 {
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            position: relative;
            letter-spacing: 3px;
        }

        h1 {
            font-size: 4em;
            font-weight: 900;
            background: linear-gradient(90deg, var(--neon-cyan), var(--neon-blue), var(--neon-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: gradient-shift 3s ease infinite;
            filter: drop-shadow(0 0 20px rgba(0,245,212,0.3));
        }

        @keyframes gradient-shift {
            0%, 100% { filter: hue-rotate(0deg); }
            50% { filter: hue-rotate(30deg); }
        }

        h2 {
            font-size: 2.5em;
            color: var(--neon-cyan);
            margin-bottom: 40px;
            text-shadow: 0 0 20px var(--neon-cyan);
        }

        h2::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(90deg, var(--neon-cyan), transparent);
            animation: line-grow 1s ease;
        }

        @keyframes line-grow {
            from { width: 0; }
            to { width: 100%; }
        }

        /* Слайд 1 - Титульный с анимированным логотипом */
        .title-slide {
            position: relative;
        }

        .dna-helix {
            position: absolute;
            width: 300px;
            height: 400px;
            right: 100px;
            top: 50%;
            transform: translateY(-50%);
            opacity: 0.3;
        }

        .helix-strand {
            position: absolute;
            width: 100%;
            height: 100%;
            border: 2px solid var(--neon-cyan);
            border-radius: 50%;
            animation: rotate-helix 10s linear infinite;
        }

        .helix-strand:nth-child(1) { animation-delay: 0s; }
        .helix-strand:nth-child(2) { animation-delay: -5s; transform: rotateY(60deg); }

        @keyframes rotate-helix {
            from { transform: rotateX(0deg) rotateY(0deg); }
            to { transform: rotateX(360deg) rotateY(360deg); }
        }

        .subtitle {
            font-size: 1.5em;
            color: var(--neon-blue);
            margin: 20px 0;
            font-weight: 300;
            letter-spacing: 5px;
        }

        .author-block {
            margin-top: 50px;
            padding: 30px 50px;
            background: var(--panel-bg);
            border: 1px solid rgba(0,245,212,0.3);
            position: relative;
            clip-path: polygon(0 0, 95% 0, 100% 20%, 100% 100%, 5% 100%, 0 80%);
        }

        .author-block::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--neon-cyan), transparent);
            animation: scan-line 2s linear infinite;
        }

        @keyframes scan-line {
            from { transform: translateX(-100%); }
            to { transform: translateX(100%); }
        }

        .author-name {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8em;
            color: var(--neon-cyan);
            text-shadow: 0 0 10px var(--neon-cyan);
        }

        .author-info {
            color: #888;
            font-size: 1.1em;
            margin-top: 10px;
        }

        /* Слайд 2 - Парадокс чисел с анимированными счётчиками */
        .numbers-showcase {
            display: flex;
            gap: 100px;
            align-items: center;
            margin: 40px 0;
        }

        .number-box {
            text-align: center;
            position: relative;
            padding: 40px;
            background: var(--panel-bg);
            border: 1px solid rgba(255,255,255,0.1);
            transition: all 0.5s;
        }

        .number-box:hover {
            border-color: var(--neon-cyan);
            box-shadow: 0 0 40px rgba(0,245,212,0.2);
            transform: scale(1.05);
        }

        .number-box::after {
            content: '';
            position: absolute;
            inset: -2px;
            background: linear-gradient(45deg, var(--neon-cyan), var(--neon-purple), var(--neon-pink));
            z-index: -1;
            opacity: 0;
            transition: opacity 0.5s;
        }

        .number-box:hover::after {
            opacity: 1;
        }

        .counter {
            font-family: 'Orbitron', sans-serif;
            font-size: 5em;
            font-weight: 900;
            display: block;
            background: linear-gradient(180deg, #fff, var(--neon-cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .vs-hexagon {
            width: 100px;
            height: 115px;
            background: linear-gradient(135deg, var(--neon-pink), var(--neon-purple));
            clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Orbitron', sans-serif;
            font-size: 1.5em;
            font-weight: bold;
            animation: pulse-hex 2s ease infinite;
        }

        @keyframes pulse-hex {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .genes-multiplier {
            margin-top: 30px;
            padding: 20px 40px;
            background: linear-gradient(90deg, rgba(245,0,155,0.2), rgba(155,93,229,0.2));
            border-left: 4px solid var(--neon-pink);
            font-family: 'Orbitron', sans-serif;
            font-size: 1.3em;
            position: relative;
            overflow: hidden;
        }

        .genes-multiplier::before {
            content: '360x';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 3em;
            opacity: 0.1;
            color: var(--neon-pink);
        }

        /* Слайд 3 - Микробиом с интерактивными картами */
        .microbiome-orbit {
            position: relative;
            width: 600px;
            height: 400px;
        }

        .center-core {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: radial-gradient(circle, var(--neon-cyan), transparent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Orbitron', sans-serif;
            font-size: 1.2em;
            text-align: center;
            box-shadow: 0 0 60px var(--neon-cyan);
            animation: core-pulse 3s ease infinite;
            z-index: 10;
        }

        @keyframes core-pulse {
            0%, 100% { box-shadow: 0 0 60px var(--neon-cyan); }
            50% { box-shadow: 0 0 100px var(--neon-cyan), 0 0 140px var(--neon-blue); }
        }

        .orbit-ring {
            position: absolute;
            border: 1px dashed rgba(0,245,212,0.3);
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .orbit-ring:nth-child(2) { width: 300px; height: 300px; }
        .orbit-ring:nth-child(3) { width: 450px; height: 450px; }

        .orbit-item {
            position: absolute;
            padding: 15px 25px;
            background: var(--panel-bg);
            border: 1px solid var(--neon-cyan);
            font-size: 0.9em;
            transition: all 0.3s;
            cursor: pointer;
        }

        .orbit-item:hover {
            background: rgba(0,245,212,0.2);
            transform: scale(1.1);
            box-shadow: 0 0 30px var(--neon-cyan);
        }

        .orbit-item:nth-child(4) { top: 10%; left: 50%; transform: translateX(-50%); }
        .orbit-item:nth-child(5) { top: 50%; right: 5%; transform: translateY(-50%); }
        .orbit-item:nth-child(6) { bottom: 10%; left: 50%; transform: translateX(-50%); }
        .orbit-item:nth-child(7) { top: 50%; left: 5%; transform: translateY(-50%); }

        /* Слайд 4 - Локализации с голографическими картами */
        .holo-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 20px;
            margin: 40px 0;
        }

        .holo-card {
            background: var(--panel-bg);
            border: 1px solid rgba(0,245,212,0.2);
            padding: 30px 20px;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: all 0.5s;
            clip-path: polygon(0 0, 100% 0, 100% 85%, 85% 100%, 0 100%);
        }

        .holo-card::before {
            content: '';
            position: absolute;
            top: -100%;
            left: -100%;
            width: 300%;
            height: 300%;
            background: linear-gradient(45deg, transparent, rgba(0,245,212,0.1), transparent);
            transform: rotate(45deg);
            transition: all 0.5s;
        }

        .holo-card:hover::before {
            top: 100%;
            left: 100%;
        }

        .holo-card:hover {
            border-color: var(--neon-cyan);
            transform: translateY(-10px);
        }

        .holo-icon {
            font-size: 3em;
            margin-bottom: 15px;
            display: block;
        }

        .holo-title {
            font-family: 'Orbitron', sans-serif;
            color: var(--neon-cyan);
            font-size: 1em;
            margin-bottom: 10px;
        }

        .holo-stat {
            font-size: 0.85em;
            color: #888;
        }

        /* Слайд 5 - Уникальность с морфингом */
        .morph-container {
            display: flex;
            gap: 50px;
            align-items: center;
        }

        .morph-panel {
            width: 400px;
            height: 300px;
            background: var(--panel-bg);
            border: 1px solid rgba(255,255,255,0.1);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        .morph-panel.unique {
            border-color: var(--neon-pink);
        }

        .morph-panel.functional {
            border-color: var(--neon-cyan);
        }

        .morph-header {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.5em;
            margin-bottom: 20px;
        }

        .unique .morph-header { color: var(--neon-pink); }
        .functional .morph-header { color: var(--neon-cyan); }

        .morph-arrow {
            font-size: 3em;
            color: var(--neon-yellow);
            animation: arrow-bounce 1s ease infinite;
        }

        @keyframes arrow-bounce {
            0%, 100% { transform: translateX(0); }
            50% { transform: translateX(20px); }
        }

        .conclusion-banner {
            margin-top: 40px;
            padding: 25px 50px;
            background: linear-gradient(90deg, rgba(0,245,212,0.1), rgba(0,187,249,0.1));
            border: 1px solid var(--neon-cyan);
            text-align: center;
            position: relative;
        }

        .conclusion-banner::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);
            opacity: 0;
            animation: shimmer 3s infinite;
        }

        @keyframes shimmer {
            0%, 100% { opacity: 0; transform: translateX(-100%); }
            50% { opacity: 0.3; transform: translateX(100%); }
        }

        /* Слайд 6 - Методы с терминалом */
        .terminal-window {
            width: 900px;
            background: #0d0d12;
            border: 1px solid var(--neon-cyan);
            border-radius: 10px 10px 0 0;
            overflow: hidden;
        }

        .terminal-header {
            background: rgba(0,245,212,0.1);
            padding: 10px 20px;
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .terminal-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }

        .terminal-dot:nth-child(1) { background: var(--neon-pink); }
        .terminal-dot:nth-child(2) { background: var(--neon-yellow); }
        .terminal-dot:nth-child(3) { background: var(--neon-cyan); }

        .terminal-body {
            padding: 30px;
            font-family: 'Courier New', monospace;
            font-size: 1.1em;
            line-height: 1.8;
        }

        .terminal-line {
            margin: 10px 0;
            opacity: 0;
            animation: type-line 0.5s forwards;
        }

        .terminal-line:nth-child(1) { animation-delay: 0.2s; }
        .terminal-line:nth-child(2) { animation-delay: 0.6s; }
        .terminal-line:nth-child(3) { animation-delay: 1s; }
        .terminal-line:nth-child(4) { animation-delay: 1.4s; }

        @keyframes type-line {
            to { opacity: 1; }
        }

        .cmd { color: var(--neon-cyan); }
        .param { color: var(--neon-yellow); }
        .output { color: #888; }

        .method-highlight-box {
            margin-top: 30px;
            padding: 20px;
            background: linear-gradient(135deg, rgba(0,187,249,0.1), rgba(155,93,229,0.1));
            border-left: 4px solid var(--neon-blue);
            font-family: 'Orbitron', sans-serif;
        }

        /* Слайд 7 - Мульти-омика с нейронной сетью */
        .neural-network {
            position: relative;
            width: 700px;
            height: 500px;
        }

        .neural-node {
            position: absolute;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: var(--panel-bg);
            border: 2px solid var(--neon-cyan);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 0.75em;
            text-align: center;
            transition: all 0.3s;
            cursor: pointer;
        }

        .neural-node:hover {
            background: rgba(0,245,212,0.2);
            box-shadow: 0 0 30px var(--neon-cyan);
            transform: scale(1.1);
        }

        .neural-node.center {
            width: 120px;
            height: 120px;
            background: radial-gradient(circle, var(--neon-purple), transparent);
            border-color: var(--neon-purple);
            box-shadow: 0 0 40px var(--neon-purple);
        }

        .neural-icon { font-size: 1.5em; margin-bottom: 3px; }

        svg.connections {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        path.connection {
            fill: none;
            stroke: rgba(0,245,212,0.3);
            stroke-width: 2;
            stroke-dasharray: 5,5;
            animation: dash-flow 2s linear infinite;
        }

        @keyframes dash-flow {
            to { stroke-dashoffset: -10; }
        }

        /* Слайд 8 - Результаты с голограммами */
        .holo-stats {
            display: flex;
            gap: 30px;
            margin: 40px 0;
        }

        .holo-stat-card {
            width: 200px;
            height: 250px;
            background: var(--panel-bg);
            border: 1px solid rgba(0,245,212,0.3);
            position: relative;
            transform-style: preserve-3d;
            transition: transform 0.5s;
        }

        .holo-stat-card:hover {
            transform: rotateY(10deg) rotateX(-5deg);
        }

        .holo-stat-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, transparent 40%, rgba(0,245,212,0.1) 50%, transparent 60%);
            animation: hologram-shine 3s infinite;
        }

        @keyframes hologram-shine {
            0%, 100% { transform: translateX(-100%) translateY(-100%); }
            50% { transform: translateX(100%) translateY(100%); }
        }

        .stat-number-holo {
            font-family: 'Orbitron', sans-serif;
            font-size: 3.5em;
            font-weight: 900;
            color: var(--neon-cyan);
            text-shadow: 0 0 20px var(--neon-cyan);
            position: absolute;
            top: 30%;
            left: 50%;
            transform: translateX(-50%);
        }

        .stat-label-holo {
            position: absolute;
            bottom: 30px;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 0.9em;
            color: #888;
        }

        /* Слайд 9 - Три исследования с таймлайном */
        .timeline-3d {
            display: flex;
            gap: 40px;
            perspective: 1000px;
        }

        .timeline-card {
            width: 300px;
            background: var(--panel-bg);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 30px;
            transform: rotateY(-5deg);
            transition: all 0.5s;
            position: relative;
        }

        .timeline-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--accent-color);
        }

        .timeline-card:nth-child(1) { --accent-color: var(--neon-pink); }
        .timeline-card:nth-child(2) { --accent-color: var(--neon-cyan); }
        .timeline-card:nth-child(3) { --accent-color: var(--neon-yellow); }

        .timeline-card:hover {
            transform: rotateY(0) translateZ(50px);
            border-color: var(--accent-color);
        }

        .timeline-icon {
            font-size: 3em;
            margin-bottom: 20px;
            filter: drop-shadow(0 0 10px var(--accent-color));
        }

        .timeline-stats {
            margin-top: 20px;
            padding: 15px;
            background: rgba(0,0,0,0.3);
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9em;
            color: var(--accent-color);
        }

        /* Слайд 10 - Диагностика с индикаторами */
        .diag-indicators {
            display: flex;
            gap: 50px;
            margin: 50px 0;
        }

        .indicator {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            border: 3px solid;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            animation: indicator-pulse 2s ease infinite;
        }

        .indicator:nth-child(1) { border-color: var(--neon-cyan); animation-delay: 0s; }
        .indicator:nth-child(2) { border-color: var(--neon-pink); animation-delay: 0.3s; }
        .indicator:nth-child(3) { border-color: var(--neon-yellow); animation-delay: 0.6s; }

        @keyframes indicator-pulse {
            0%, 100% { box-shadow: 0 0 20px currentColor; }
            50% { box-shadow: 0 0 40px currentColor, 0 0 60px currentColor; }
        }

        .indicator-inner {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: var(--panel-bg);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 20px;
        }

        .indicator-icon { font-size: 2.5em; margin-bottom: 10px; }
        .indicator-label { font-size: 0.85em; color: #888; }

        /* Слайд 11 - Терапия с прогресс-барами */
        .therapy-progress {
            display: flex;
            flex-direction: column;
            gap: 25px;
            width: 800px;
        }

        .progress-item {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .progress-label {
            width: 150px;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9em;
            color: var(--neon-cyan);
        }

        .progress-bar {
            flex: 1;
            height: 30px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            position: relative;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--neon-cyan), var(--neon-blue));
            position: relative;
            animation: fill-grow 1.5s ease forwards;
            width: 0;
        }

        @keyframes fill-grow {
            to { width: var(--progress); }
        }

        .progress-value {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            font-family: 'Orbitron', sans-serif;
            font-size: 0.8em;
            color: #fff;
        }

        /* Слайд 12 - Будущее с матрицей */
        .matrix-rain {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            opacity: 0.1;
            pointer-events: none;
        }

        .matrix-column {
            position: absolute;
            top: -100%;
            font-family: 'Courier New', monospace;
            font-size: 14px;
            color: var(--neon-cyan);
            animation: matrix-fall 10s linear infinite;
        }

        @keyframes matrix-fall {
            to { top: 100%; }
        }

        .future-stages {
            display: flex;
            gap: 40px;
            align-items: center;
            z-index: 10;
        }

        .stage-node {
            width: 250px;
            padding: 40px;
            background: var(--panel-bg);
            border: 1px solid;
            text-align: center;
            position: relative;
            transition: all 0.5s;
        }

        .stage-now { border-color: #444; }
        .stage-near { border-color: var(--neon-blue); transform: scale(1.1); }
        .stage-future { 
            border-color: var(--neon-cyan); 
            box-shadow: 0 0 60px rgba(0,245,212,0.3);
        }

        .stage-node:hover {
            transform: translateY(-20px) scale(1.05);
        }

        .stage-arrow {
            font-size: 2em;
            color: var(--neon-cyan);
            animation: arrow-glow 1s ease infinite;
        }

        @keyframes arrow-glow {
            0%, 100% { opacity: 0.5; text-shadow: 0 0 10px var(--neon-cyan); }
            50% { opacity: 1; text-shadow: 0 0 30px var(--neon-cyan); }
        }

        /* Слайд 13 - Заключение с частицами */
        .conclusion-particles {
            position: absolute;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .conclusion-text {
            font-size: 1.5em;
            line-height: 2;
            text-align: center;
            z-index: 10;
        }

        .highlight-word {
            display: inline-block;
            padding: 5px 15px;
            margin: 5px;
            background: var(--panel-bg);
            border: 1px solid var(--neon-cyan);
            font-family: 'Orbitron', sans-serif;
            transition: all 0.3s;
            cursor: pointer;
        }

        .highlight-word:hover {
            background: var(--neon-cyan);
            color: var(--dark-bg);
            transform: scale(1.1);
        }

        .final-quote {
            margin-top: 50px;
            padding: 30px 60px;
            border: 2px solid var(--neon-purple);
            position: relative;
            font-family: 'Orbitron', sans-serif;
            font-size: 1.3em;
            color: var(--neon-purple);
            text-shadow: 0 0 20px var(--neon-purple);
        }

        .final-quote::before,
        .final-quote::after {
            content: '"';
            position: absolute;
            font-size: 4em;
            color: var(--neon-purple);
            opacity: 0.5;
        }

        .final-quote::before { top: -20px; left: 20px; }
        .final-quote::after { bottom: -40px; right: 20px; }

        /* Слайд 14 - Литература с терминалом 2.0 */
        .lit-terminal {
            width: 1000px;
            background: #0a0a0f;
            border: 1px solid var(--neon-cyan);
            position: relative;
        }

        .lit-terminal::before {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0,245,212,0.03) 2px,
                rgba(0,245,212,0.03) 4px
            );
            pointer-events: none;
        }

        .lit-header {
            background: rgba(0,245,212,0.1);
            padding: 15px 25px;
            font-family: 'Orbitron', sans-serif;
            color: var(--neon-cyan);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .lit-body {
            padding: 30px;
            font-family: 'Courier New', monospace;
        }

        .lit-entry {
            margin: 20px 0;
            padding: 20px;
            background: rgba(255,255,255,0.02);
            border-left: 3px solid;
            position: relative;
            overflow: hidden;
        }

        .lit-entry::before {
            content: '>';
            position: absolute;
            left: 10px;
            color: var(--neon-cyan);
        }

        .lit-entry:nth-child(1) { border-color: var(--neon-cyan); }
        .lit-entry:nth-child(2) { border-color: var(--neon-blue); }
        .lit-entry:nth-child(3) { border-color: var(--neon-purple); }
        .lit-entry:nth-child(4) { border-color: var(--neon-pink); }

        .lit-year-badge {
            display: inline-block;
            padding: 3px 10px;
            background: var(--neon-cyan);
            color: var(--dark-bg);
            font-family: 'Orbitron', sans-serif;
            font-size: 0.8em;
            margin-right: 15px;
        }

        .lit-title-text {
            color: #fff;
            font-size: 1.1em;
            margin: 10px 0;
        }

        .lit-authors-text {
            color: #888;
            font-size: 0.9em;
        }

        .contact-footer {
            margin-top: 30px;
            padding: 20px;
            background: rgba(0,245,212,0.05);
            text-align: center;
            font-family: 'Orbitron', sans-serif;
        }

        .contact-line {
            color: var(--neon-cyan);
            font-size: 1.2em;
            letter-spacing: 2px;
        }

        /* Адаптивность */
        @media (max-width: 1200px) {
            h1 { font-size: 2.5em; }
            h2 { font-size: 1.8em; }
            .numbers-showcase { gap: 50px; }
            .holo-grid { grid-template-columns: repeat(3, 1fr); }
        }
    </style>
</head>
<body>
    <div class="grid-overlay"></div>
    <div class="particles" id="particles"></div>
    
    <div class="presentation">
        
        <!-- Слайд 1: Титульный -->
        <div class="slide active title-slide">
            <div class="dna-helix">
                <div class="helix-strand"></div>
                <div class="helix-strand"></div>
            </div>
            <h1>Проект «Микробиом человека»</h1>
            <p class="subtitle">Human Microbiome Project</p>
            <div class="author-block">
                <div class="author-name">ЛЕОН ЛАНДАУ</div>
                <div class="author-info">Студент 2 курса ФФМ МГУ • Доклад по микробиологии</div>
            </div>
        </div>

        <!-- Слайд 2: Парадокс чисел -->
        <div class="slide">
            <h2>Парадокс чисел</h2>
            <div class="numbers-showcase">
                <div class="number-box">
                    <span class="counter">10¹³</span>
                    <p>Человеческих клеток</p>
                </div>
                <div class="vs-hexagon">VS</div>
                <div class="number-box">
                    <span class="counter">10¹⁴</span>
                    <p>Микробных клеток</p>
                </div>
            </div>
            <div class="genes-multiplier">
                Генетический потенциал: микробиом превосходит человеческий геном в 360 раз
            </div>
        </div>

        <!-- Слайд 3: Микробиом -->
        <div class="slide">
            <h2>Что такое микробиом?</h2>
            <div class="microbiome-orbit">
                <div class="orbit-ring"></div>
                <div class="orbit-ring"></div>
                <div class="center-core">МИКРО<br>БИОМ</div>
                <div class="orbit-item">🧬 Микроорганизмы</div>
                <div class="orbit-item">🧪 Гены</div>
                <div class="orbit-item">⚗️ Метаболиты</div>
                <div class="orbit-item">🔄 Взаимодействие</div>
            </div>
        </div>

        <!-- Слайд 4: Локализации -->
        <div class="slide">
            <h2>Объекты исследования</h2>
            <div class="holo-grid">
                <div class="holo-card">
                    <span class="holo-icon">🫃</span>
                    <div class="holo-title">КИШЕЧНИК</div>
                    <div class="holo-stat">~1000 видов</div>
                </div>
                <div class="holo-card">
                    <span class="holo-icon">✋</span>
                    <div class="holo-title">КОЖА</div>
                    <div class="holo-stat">Топографическая специфичность</div>
                </div>
                <div class="holo-card">
                    <span class="holo-icon">👄</span>
                    <div class="holo-title">РОТ</div>
                    <div class="holo-stat">Биоплёнки</div>
                </div>
                <div class="holo-card">
                    <span class="holo-icon">🌸</span>
                    <div class="holo-title">ВЛАГАЛИЩЕ</div>
                    <div class="holo-stat">Доминирование лактобацилл</div>
                </div>
                <div class="holo-card">
                    <span class="holo-icon">👃</span>
                    <div class="holo-title">НОС</div>
                    <div class="holo-stat">Респираторные патогены</div>
                </div>
            </div>
        </div>

        <!-- Слайд 5: Уникальность -->
        <div class="slide">
            <h2>Уникальность vs функциональность</h2>
            <div class="morph-container">
                <div class="morph-panel unique">
                    <div class="morph-header">ТАКСОНОМИЯ</div>
                    <p>Уникальна у каждого</p>
                    <p>Используется как идентификатор</p>
                    <p>80-90% вариабельности</p>
                </div>
                <div class="morph-arrow">→</div>
                <div class="morph-panel functional">
                    <div class="morph-header">ФУНКЦИЯ</div>
                    <p>Стабильна у всех</p>
                    <p>Конвергентный метаболизм</p>
                    <p>18 видов общего ядра</p>
                </div>
            </div>
            <div class="conclusion-banner">
                Функциональная избыточность: разные бактерии выполняют одни функции
            </div>
        </div>

        <!-- Слайд 6: Методы -->
        <div class="slide">
            <h2>Методы идентификации</h2>
            <div class="terminal-window">
                <div class="terminal-header">
                    <div class="terminal-dot"></div>
                    <div class="terminal-dot"></div>
                    <div class="terminal-dot"></div>
                    <span style="margin-left: 10px; color: var(--neon-cyan);">sequencing_protocol.sh</span>
                </div>
                <div class="terminal-body">
                    <div class="terminal-line"><span class="cmd">$</span> <span class="param">16S_rRNA_sequencing</span> <span class="output">--taxonomic-analysis --quick-screen</span></div>
                    <div class="terminal-line"><span class="cmd">$</span> <span class="param">metagenomic_shotgun</span> <span class="output">--full-DNA --functional-analysis</span></div>
                    <div class="terminal-line"><span class="cmd">$</span> <span class="param">culturomics</span> <span class="output">--novel-strains --reference-bank</span></div>
                    <div class="terminal-line"><span class="cmd">$</span> <span class="output">MetaHIT: 576.7 GB | 3.3M unique genes</span></div>
                </div>
            </div>
            <div class="method-highlight-box">
                Ключевое достижение: 3000+ референсных геномов «некультивабельных» бактерий
            </div>
        </div>

        <!-- Слайд 7: Мульти-омика -->
        <div class="slide">
            <h2>Мульти-омный подход iHMP</h2>
            <div class="neural-network" id="neural-network">
                <svg class="connections">
                    <path class="connection" d="M 350 250 L 200 100" />
                    <path class="connection" d="M 350 250 L 550 150" />
                    <path class="connection" d="M 350 250 L 550 350" />
                    <path class="connection" d="M 350 250 L 200 400" />
                    <path class="connection" d="M 350 250 L 100 250" />
                    <path class="connection" d="M 350 250 L 600 250" />
                </svg>
                <div class="neural-node center" style="top: 210px; left: 310px;">
                    <div class="neural-icon">🧬</div>
                    <div>ОБРАЗЕЦ</div>
                </div>
                <div class="neural-node" style="top: 60px; left: 160px;">
                    <div class="neural-icon">🧬</div>
                    <div>Метагеномика</div>
                </div>
                <div class="neural-node" style="top: 110px; left: 510px;">
                    <div class="neural-icon">📋</div>
                    <div>Метатранскриптомика</div>
                </div>
                <div class="neural-node" style="top: 310px; left: 510px;">
                    <div class="neural-icon">🥚</div>
                    <div>Метапротеомика</div>
                </div>
                <div class="neural-node" style="top: 360px; left: 160px;">
                    <div class="neural-icon">⚗️</div>
                    <div>Метаболомика</div>
                </div>
                <div class="neural-node" style="top: 210px; left: 60px;">
                    <div class="neural-icon">👤</div>
                    <div>Хост-омика</div>
                </div>
                <div class="neural-node" style="top: 210px; left: 560px;">
                    <div class="neural-icon">🦠</div>
                    <div>Виромика</div>
                </div>
            </div>
        </div>

        <!-- Слайд 8: Результаты 1 -->
        <div class="slide">
            <h2>Результаты фазы 1 (2007–2014)</h2>
            <div class="holo-stats">
                <div class="holo-stat-card">
                    <div class="stat-number-holo">300+</div>
                    <div class="stat-label-holo">здоровых доноров</div>
                </div>
                <div class="holo-stat-card">
                    <div class="stat-number-holo">18</div>
                    <div class="stat-label-holo">участков тела</div>
                </div>
                <div class="holo-stat-card">
                    <div class="stat-number-holo">10K+</div>
                    <div class="stat-label-holo">видов микробов</div>
                </div>
                <div class="holo-stat-card">
                    <div class="stat-number-holo">18</div>
                    <div class="stat-label-holo">видов общего ядра</div>
                </div>
            </div>
        </div>

        <!-- Слайд 9: Три исследования -->
        <div class="slide">
            <h2>Фаза 2: iHMP</h2>
            <div class="timeline-3d">
                <div class="timeline-card">
                    <div class="timeline-icon">🤰</div>
                    <h3>Беременность</h3>
                    <p>Преждевременные роды</p>
                    <div class="timeline-stats">1500 образцов</div>
                </div>
                <div class="timeline-card">
                    <div class="timeline-icon">🫀</div>
                    <h3>ВЗК</h3>
                    <p>Болезнь Крона, колит</p>
                    <div class="timeline-stats">1785 образцов | 132 пациента</div>
                </div>
                <div class="timeline-card">
                    <div class="timeline-icon">🩸</div>
                    <h3>Преддиабет</h3>
                    <p>Инсулинорезистентность</p>
                    <div class="timeline-stats">106 пациентов | 4 года</div>
                </div>
            </div>
        </div>

        <!-- Слайд 10: Диагностика -->
        <div class="slide">
            <h2>Клиническое применение: диагностика</h2>
            <div class="diag-indicators">
                <div class="indicator">
                    <div class="indicator-inner">
                        <span class="indicator-icon">🧪</span>
                        <span class="indicator-label">Скрининг рака</span>
                    </div>
                </div>
                <div class="indicator">
                    <div class="indicator-inner">
                        <span class="indicator-icon">🤰</span>
                        <span class="indicator-label">Преждевременные роды</span>
                    </div>
                </div>
                <div class="indicator">
                    <div class="indicator-inner">
                        <span class="indicator-icon">💉</span>
                        <span class="indicator-label">Диабет 2 типа</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Слайд 11: Терапия -->
        <div class="slide">
            <h2>Клиническое применение: терапия</h2>
            <div class="therapy-progress">
                <div class="progress-item">
                    <div class="progress-label">FMT</div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="--progress: 90%;">
                            <span class="progress-value">>90%</span>
                        </div>
                    </div>
                    <span style="color: var(--neon-cyan); font-family: 'Orbitron';">C. difficile</span>
                </div>
                <div class="progress-item">
                    <div class="progress-label">Пробиотики</div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="--progress: 60%;">
                            <span class="progress-value">60%</span>
                        </div>
                    </div>
                    <span style="color: #888;">Коррекция дисбиоза</span>
                </div>
                <div class="progress-item">
                    <div class="progress-label">Постбиотики</div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="--progress: 75%;">
                            <span class="progress-value">75%</span>
                        </div>
                    </div>
                    <span style="color: #888;">Бутират, пропионат</span>
                </div>
                <div class="progress-item">
                    <div class="progress-label">Персонализация</div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="--progress: 85%;">
                            <span class="progress-value">85%</span>
                        </div>
                    </div>
                    <span style="color: #888;">Питание по профилю</span>
                </div>
            </div>
        </div>

        <!-- Слайд 12: Будущее -->
        <div class="slide">
            <h2>Будущее: engineered probiotics</h2>
            <div class="matrix-rain" id="matrix"></div>
            <div class="future-stages">
                <div class="stage-node stage-now">
                    <h3>СЕЙЧАС</h3>
                    <p>Стандартные пробиотики</p>
                    <p style="font-size: 0.9em; color: #888;">Lactobacillus, Bifidobacterium</p>
                </div>
                <div class="stage-arrow">→</div>
                <div class="stage-node stage-near">
                    <h3>БЛИЖАЙШЕЕ</h3>
                    <p>Синбиотики</p>
                    <p style="font-size: 0.9em; color: #888;">Пробиотик + пребиотик</p>
                </div>
                <div class="stage-arrow">→</div>
                <div class="stage-node stage-future">
                    <h3>ПЕРСПЕКТИВА</h3>
                    <p>Engineered probiotics</p>
                    <p style="font-size: 0.9em; color: var(--neon-cyan);">Бактерии-синтезаторы лекарств</p>
                </div>
            </div>
        </div>

        <!-- Слайд 13: Заключение -->
        <div class="slide">
            <h2>Заключение</h2>
            <div class="conclusion-text">
                <span class="highlight-word">Микробиом</span> — полноценный орган человека<br>
                <span class="highlight-word">HMP</span> создал инфраструктуру системной биологии<br>
                <span class="highlight-word">Медицина</span> будущего требует учёта микробной составляющей
            </div>
            <div class="final-quote">
                Мы — метагеномный суперорганизм: эукариот + прокариоты в симбиозе
            </div>
        </div>

        <!-- Слайд 14: Литература -->
        <div class="slide">
            <h2>Литература</h2>
            <div class="lit-terminal">
                <div class="lit-header">
                    <span>REFERENCES.bib</span>
                    <span style="font-size: 0.8em; color: var(--neon-cyan);">[READ-ONLY]</span>
                </div>
                <div class="lit-body">
                    <div class="lit-entry">
                        <span class="lit-year-badge">2012</span>
                        <span style="color: var(--neon-cyan);">Nature</span>
                        <div class="lit-title-text">Structure, function and diversity of the healthy human microbiome</div>
                        <div class="lit-authors-text">The Human Microbiome Project Consortium</div>
                    </div>
                    <div class="lit-entry">
                        <span class="lit-year-badge">2019</span>
                        <span style="color: var(--neon-blue);">Nature</span>
                        <div class="lit-title-text">Multi-omics of the gut microbial ecosystem in inflammatory bowel diseases</div>
                        <div class="lit-authors-text">Lloyd-Price J. et al.</div>
                    </div>
                    <div class="lit-entry">
                        <span class="lit-year-badge">2019</span>
                        <span style="color: var(--neon-purple);">Nature Medicine</span>
                        <div class="lit-title-text">The vaginal microbiome and preterm birth</div>
                        <div class="lit-authors-text">Fettweis J.M. et al.</div>
                    </div>
                    <div class="lit-entry">
                        <span class="lit-year-badge">2019</span>
                        <span style="color: var(--neon-pink);">Nature</span>
                        <div class="lit-title-text">Longitudinal multi-omics of host–microbe dynamics in prediabetes</div>
                        <div class="lit-authors-text">Zhou W. et al.</div>
                    </div>
                </div>
                <div class="contact-footer">
                    <div class="contact-line">hmpdacc.org • Спасибо за внимание</div>
                </div>
            </div>
        </div>

    </div>

    <div class="nav">
        <button onclick="prevSlide()">◀ НАЗАД</button>
        <button onclick="nextSlide()">ВПЕРЁД ▶</button>
    </div>
    <div class="slide-counter">
        <span id="current">1</span> / <span id="total">14</span>
    </div>

    <script>
        // Генерация частиц
        const particlesContainer = document.getElementById('particles');
        for (let i = 0; i < 50; i++) {
            const particle = document.createElement('div');
            particle.className = 'particle';
            particle.style.left = Math.random() * 100 + '%';
            particle.style.animationDelay = Math.random() * 8 + 's';
            particle.style.animationDuration = (5 + Math.random() * 5) + 's';
            particlesContainer.appendChild(particle);
        }

        // Матрица для слайда 12
        const matrixContainer = document.getElementById('matrix');
        const chars = '01アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン';
        for (let i = 0; i < 20; i++) {
            const column = document.createElement('div');
            column.className = 'matrix-column';
            column.style.left = (i * 5) + '%';
            column.style.animationDelay = Math.random() * 10 + 's';
            column.style.animationDuration = (8 + Math.random() * 5) + 's';
            let text = '';
            for (let j = 0; j < 50; j++) {
                text += chars[Math.floor(Math.random() * chars.length)] + '<br>';
            }
            column.innerHTML = text;
            matrixContainer.appendChild(column);
        }

        // Навигация
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide');
        const totalSlides = slides.length;
        document.getElementById('total').textContent = totalSlides;

        function showSlide(n) {
            slides.forEach(slide => slide.classList.remove('active'));
            currentSlide = (n + totalSlides) % totalSlides;
            slides[currentSlide].classList.add('active');
            document.getElementById('current').textContent = currentSlide + 1;
            
            // Перезапуск анимаций прогресс-баров
            if (currentSlide === 10) {
                document.querySelectorAll('.progress-fill').forEach(bar => {
                    bar.style.animation = 'none';
                    setTimeout(() => bar.style.animation = '', 10);
                });
            }
        }

        function nextSlide() { showSlide(currentSlide + 1); }
        function prevSlide() { showSlide(currentSlide - 1); }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowRight' || e.key === ' ') nextSlide();
            if (e.key === 'ArrowLeft') prevSlide();
        });

        // Свайпы
        let touchStartX = 0;
        document.addEventListener('touchstart', e => touchStartX = e.changedTouches[0].screenX);
        document.addEventListener('touchend', e => {
            const diff = touchStartX - e.changedTouches[0].screenX;
            if (diff > 50) nextSlide();
            if (diff < -50) prevSlide();
        });
    </script>
</body>
</html>

